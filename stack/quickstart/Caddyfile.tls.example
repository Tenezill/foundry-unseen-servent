# TLS profile template — `make setup` instantiates this as Caddyfile.tls,
# replacing {{DOMAIN_APP}}, {{DOMAIN_VTT}}, {{ACME_EMAIL}}.
{
	email {{ACME_EMAIL}}
}

{{DOMAIN_APP}} {
	handle /api/* {
		reverse_proxy gateway:8090
	}
	handle /healthz {
		reverse_proxy gateway:8090
	}
	# Same-origin Foundry ASSET proxy (2026-07-18): portraits/effect icons.
	# Image files only — everything else 404s so no Foundry UI is exposed.
	handle_path /fvtt/* {
		# respond runs before reverse_proxy in Caddy's directive order, so
		# the 404 must be matcher-scoped to NON-images; images fall through.
		@notimg not path_regexp \.(webp|png|jpe?g|gif|svg|avif)$
		respond @notimg 404
		reverse_proxy foundry:30000
	}
	handle {
		root * /srv/app
		try_files {path} /index.html
		file_server
	}
	encode gzip
}

{{DOMAIN_VTT}} {
	reverse_proxy foundry:30000
}
